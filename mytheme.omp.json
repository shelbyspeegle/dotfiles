{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "darkGray",
          "style": "plain",
          "template": "╰─────────┈┈┈┈ ┈  ┈   ┈     ┈\n",
          "type": "text"
        },
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "╭─────────────────────────────────────",
          "type": "text"
        },
        {
          "foreground": "#D42A6D",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#C62766",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#B8245E",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#AA2257",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#9B1F50",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#8D1C49",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#7F1941",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#71163A",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#631433",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#55112C",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#470E24",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#390B1D",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#2A0816",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#1C060F",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#0E0307",
          "style": "plain",
          "template": "────",
          "type": "text"
        },
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "\n│ ",
          "type": "text"
        },
        {
          "foreground": "lightMagenta",
          "properties": {
            "style": "agnoster_full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "red",
          "style": "plain",
          "template": "✘ {{ reason .Code }} ",
          "type": "status"
        },
        {
          "foreground": "lightMagenta",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        // {
        //   "foreground": "darkGray",
        //   "properties": {

        //   },
        //   "style": "plain",
        //   "template": " {{ .HEAD }} ",
        //   "type": "git"
        // },
        // {
        //   "foreground": "#E5C07B",
        //   "properties": {
        //     "time_format": "15:04:05"
        //   },
        //   "style": "plain",
        //   "template": "[{{ .CurrentDate | date .Format }}]",
        //   "type": "time"
        // }
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "darkGray",
          "template": "{{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin",
            "always_enabled": true
          }
        }
      ],
      "type": "rprompt"
    }
  ],
  "version": 3
}
