{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "╰──",
          "type": "text"
        },
        {
          "foreground": "#B8245E",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#AA2257",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#9B1F50",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#8D1C49",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#7F1941",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#71163A",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#631433",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#55112C",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#470E24",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#390B1D",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#2A0816",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#1C060F",
          "style": "plain",
          "template": "──",
          "type": "text"
        },
        {
          "foreground": "#0E0307",
          "style": "plain",
          "template": "──\n",
          "type": "text"
        },
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "╭{{ $c := atoi (coalesce .Env.COLUMNS \"80\") }}{{ repeat (int (sub $c 2)) \"─\" }}╮",
          "type": "text"
        },
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "\n│ ",
          "type": "text"
        },
        {
          "foreground": "lightMagenta",
          "properties": {
            "style": "agnoster_full",
            "mapped_locations": {
              "~/source": "SRC"
            }
          },
          "style": "plain",
          "template": "{{ if eq .Path \"SRC\" }}<#888888>󰘬</> source {{ else if hasPrefix \"SRC/\" .Path }}<#888888>󰘬</> {{ trimPrefix \"SRC/\" .Path }} {{ else }}{{ .Path }} {{ end }}",
          "type": "path"
        },
        {
          "foreground": "red",
          "style": "plain",
          "template": "✘ {{ reason .Code }} ",
          "type": "status"
        },
        {
          "foreground": "lightMagenta",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "foreground": "#888888",
          "properties": {
            "fetch_status": true,
            "branch_icon": "󰘬 ",
            "branch_max_length": 30
          },
          "template": "{{ .HEAD }}{{ if gt .Ahead 0 }} <cyan>↑{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }} <magenta>↓{{ .Behind }}</>{{ end }}{{ $s := add (add .Staging.Added .Staging.Modified) .Staging.Deleted }}{{ if gt $s 0 }} <green>S:{{ $s }}</>{{ end }}{{ $m := add .Working.Modified .Working.Deleted }}{{ if gt $m 0 }} <yellow>M:{{ $m }}</>{{ end }}{{ if gt .Working.Untracked 0 }} <red>U:{{ .Working.Untracked }}</>{{ end }}{{ if and (eq $s 0) (eq $m 0) (eq .Working.Untracked 0) }} <green>✓ clean</>{{ end }}  ",
          "type": "git"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "darkGray",
          "template": "{{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "foreground": "darkGray",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": " [{{ .CurrentDate | date .Format }}]",
          "type": "time"
        },
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": " │",
          "type": "text"
        }
      ],
      "type": "rprompt"
    }
  ],
  "version": 3
}
