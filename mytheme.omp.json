{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "foreground": "#B1235B",
          "properties": {
            "style": "agnoster_full",
            "mapped_locations": {
              "~/source": "SRC"
            }
          },
          "style": "plain",
          "template": "\n\n{{ if eq .Path \"SRC\" }}━━━ <#888888>󰘬</> <lightMagenta>source</> {{ else if hasPrefix \"SRC/\" .Path }}━━━ <#888888>󰘬</> <lightMagenta>{{ trimPrefix \"SRC/\" .Path }}</> {{ else }}━━━ <lightMagenta>{{ .Path }}</> {{ end }}",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "newline": false,
      "filler": "<#B1235B>━</>",
      "segments": [
        {
          "foreground": "#B1235B",
          "style": "plain",
          "template": "━",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "red",
          "style": "plain",
          "template": "✘ {{ reason .Code }} ",
          "type": "status"
        },
        {
          "foreground": "lightMagenta",
          "style": "plain",
          "template": "❯ ",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "foreground": "#888888",
          "properties": {
            "fetch_status": true,
            "branch_icon": "󰘬 ",
            "branch_max_length": 30
          },
          "template": "{{ .HEAD }}{{ if gt .Ahead 0 }} <cyan>↑{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }} <magenta>↓{{ .Behind }}</>{{ end }}{{ $s := add (add .Staging.Added .Staging.Modified) .Staging.Deleted }}{{ if gt $s 0 }} <green>S:{{ $s }}</>{{ end }}{{ $m := add .Working.Modified .Working.Deleted }}{{ if gt $m 0 }} <yellow>M:{{ $m }}</>{{ end }}{{ if gt .Working.Untracked 0 }} <red>U:{{ .Working.Untracked }}</>{{ end }}{{ if and (eq $s 0) (eq $m 0) (eq .Working.Untracked 0) }} <green>✓ clean</>{{ end }}  ",
          "type": "git"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "darkGray",
          "template": "{{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "foreground": "darkGray",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": " [{{ .CurrentDate | date .Format }}]",
          "type": "time"
        }
      ],
      "type": "rprompt"
    }
  ],
  "version": 3
}
