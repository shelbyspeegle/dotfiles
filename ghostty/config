font-family = Hack Nerd Font Mono
font-thicken = 1

cursor-style = block
shell-integration-features = no-cursor

split-divider-color = #E7698E

macos-icon = custom
macos-custom-icon = "/Users/sspeegle/source/dotfiles/ghostty/claude-icon-lightpink.png"

window-padding-x = 16
window-padding-y = 0,32
window-padding-balance = true

window-save-state = always

macos-titlebar-style = tabs

unfocused-split-opacity = 0.7
unfocused-split-fill = #666666


keybind = super+s=text:s\n
keybind = super+k=text:clear\n
keybind = opt+super+left=previous_tab
keybind = opt+super+right=next_tab

